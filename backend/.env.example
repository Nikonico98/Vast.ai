# ==========================================
# ImaginaryWorld Vastai - GPU Service Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.

# Workspace root (usually /workspace on Vast.ai)
WORKSPACE=/workspace

# GPU Service Port
GPU_SERVICE_PORT=5555

# API Key for authentication (shared with Hostinger)
GPU_API_SECRET=your_secret_key_here
GPU_WORKER_URL=http://your_vastai_ip:22939
VASTAI_BEARER_TOKEN=your_bearer_token_here

# SAM3 Configuration
SAM3_ENV=sam3
SAM3_REPO=/workspace/sam3

# SAM3D Configuration
SAM3D_ENV=sam3d-objects
SAM3D_REPO=/workspace/sam-3d-objects
SAM3D_CHECKPOINT=hf

# Hugging Face Token (for model downloads)
HF_TOKEN=your_hf_token_here

# GPU Data Directory
GPU_DATA_DIR=/workspace/gpu_data

# Persistent Model Server Ports (Dual-GPU Architecture)
# GPU 0 (real/photo pipeline)
SAM3_SERVER_PORT_GPU0=5561
SAM3D_SERVER_PORT_GPU0=5562
SAM3_SERVER_URL_GPU0=http://127.0.0.1:5561
SAM3D_SERVER_URL_GPU0=http://127.0.0.1:5562
# GPU 1 (fictional pipeline)
SAM3_SERVER_PORT_GPU1=5571
SAM3D_SERVER_PORT_GPU1=5572
SAM3_SERVER_URL_GPU1=http://127.0.0.1:5571
SAM3D_SERVER_URL_GPU1=http://127.0.0.1:5572

# Vast.ai Instance Management
VASTAI_API_KEY=your_vastai_api_key_here
VASTAI_INSTANCE_ID=your_instance_id_here
