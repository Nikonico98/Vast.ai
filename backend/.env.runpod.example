# ==========================================
# Imaginary World - RunPod Configuration
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.runpod.example .env
#
# Migration from Vast.ai:
#   1. Create a RunPod Pod (see README)
#   2. Fill in RUNPOD_GPU_URL with your Pod's proxy URL
#   3. Fill in RUNPOD_API_KEY and RUNPOD_POD_ID
#   4. Remove old VASTAI_* variables (optional, backward compat is maintained)
# ==========================================

# ---- RunPod GPU Worker ----
# Format: https://{POD_ID}-{PORT}.proxy.runpod.net
# Example: https://abc123def456-5555.proxy.runpod.net
# This URL is STABLE — it never changes as long as the Pod exists!
# It's also HTTPS — no more mixed content errors!
RUNPOD_GPU_URL=https://YOUR_POD_ID-5555.proxy.runpod.net

# RunPod API Key (from https://www.runpod.io/console/user/settings)
RUNPOD_API_KEY=your_runpod_api_key_here

# RunPod Pod ID (visible in the RunPod console URL or Pod details)
RUNPOD_POD_ID=your_pod_id_here

# Shared secret between Hostinger backend and GPU worker
# Must match the GPU_API_SECRET on your RunPod GPU worker
GPU_API_SECRET=niko2026IWSecretKey

# ---- AI Services ----
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2
LUMA_API_KEY=your_luma_api_key_here

# ---- Server ----
PORT=5000
DEBUG=false
SECRET_KEY=your_flask_secret_key_here
